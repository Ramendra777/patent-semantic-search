# Environment Configuration Example
# Copy this file to .env and adjust variables for your environment

# Milvus Connection (Internal Docker DNS)
MILVUS_HOST=standalone
MILVUS_PORT=19530

# Backend Configuration
CORS_ORIGINS=http://localhost:3000,http://your-production-domain.com

# Frontend Configuration
API_BASE_URL=http://localhost:8000

# Optional: HuggingFace Token for ingestion (higher rate limits)
# HF_TOKEN=your_token_h_...
